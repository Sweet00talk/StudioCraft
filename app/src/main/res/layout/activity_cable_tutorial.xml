<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purple_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="sans-serif-condensed"
        android:text="CABLE MATCH"
        android:textColor="#00e8ff"
        android:textSize="28sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:text="Drag each cable head to the correct cable name."
        android:textColor="#E6FFFFFF"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/game_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/game_panel_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tv_instruction"
        app:layout_constraintBottom_toTopOf="@id/tv_feedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.studiocraft.CableLineView
            android:id="@+id/cable_canvas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/board_columns"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal">

            <!-- LEFT COLUMN -->
            <LinearLayout
                android:id="@+id/left_column"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="MATCH TO"
                    android:textColor="#00e8ff"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:id="@+id/left_box_1"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_left_box_bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/left_text_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mark_left_1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/left_box_2"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_left_box_bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/left_text_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mark_left_2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/left_box_3"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_left_box_bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/left_text_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mark_left_3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/left_box_4"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_left_box_bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/left_text_4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mark_left_4"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

            </LinearLayout>

            <Space
                android:layout_width="44dp"
                android:layout_height="match_parent" />

            <!-- RIGHT COLUMN -->
            <LinearLayout
                android:id="@+id/right_column"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="DRAG CABLE"
                    android:textColor="#ff27b5"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- 1. COMPOSITE -->
                <FrameLayout
                    android:id="@+id/right_slot_composite"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_right_box_bg"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/cable_composite"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/cable_composite" />
                </FrameLayout>

                <!-- 2. COMPONENT -->
                <FrameLayout
                    android:id="@+id/right_slot_component"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_right_box_bg"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/cable_component"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/cable_component" />
                </FrameLayout>

                <!-- 3. VGA -->
                <FrameLayout
                    android:id="@+id/right_slot_vga"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_right_box_bg"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/cable_vga"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/cable_vga" />
                </FrameLayout>

                <!-- 4. S-VIDEO -->
                <FrameLayout
                    android:id="@+id/right_slot_svideo"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/match_right_box_bg"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/cable_svideo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/cable_svideo" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/tv_feedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="Match all 4 cables correctly."
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/nav_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/nav_divider"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#00e8ff"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation" />

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#0c1424"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/star_big_on"
                app:tint="#00e8ff" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOME"
                android:textColor="#00e8ff"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_task"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#ff27b5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHALLENGE"
                android:textColor="#ff27b5"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_help"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="#9333EA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HELP"
                android:textColor="#9333EA"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>