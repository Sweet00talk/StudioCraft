<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purple_bg">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="sans-serif-condensed"
        android:text="QUICK NOTES"
        android:textColor="#00e8ff"
        android:textSize="32sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="(Tap on the boxes below to reveal a fun fact!)"
        android:textColor="#BDBDBD"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <LinearLayout
        android:id="@+id/layout_interlaced"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="#0c1424"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interlaced Scanning (1080i)"
            android:textColor="#ff27b5"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="• The Older Standard: Draws odd lines first, then even lines.\n• Pros: Saves bandwidth (file sizes are smaller).\n• Cons: Can cause screen flickering or blur during fast motion like sports."
            android:textColor="#E0E0E0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_interlaced_extra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#33ff27b5"
            android:padding="12dp"
            android:text="💡 Fun Fact: Used mainly by older CRT TVs and early satellite broadcasts to save transmission costs!"
            android:textColor="#ff27b5"
            android:textSize="16sp"
            android:textStyle="italic"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_progressive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:background="#0c1424"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_interlaced">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progressive Scanning (1080p)"
            android:textColor="#00e8ff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="• The Modern Standard: Draws all lines sequentially from top to bottom in one go.\n• Pros: Extremely sharp, stable, and smooth visuals.\n• Cons: Requires higher bandwidth and processing power."
            android:textColor="#E0E0E0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_progressive_extra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#3300e8ff"
            android:padding="12dp"
            android:text="💡 Fun Fact: The 'p' stands for Progressive. This is the absolute standard for PC Monitors, Console Gaming, and Netflix!"
            android:textColor="#00e8ff"
            android:textSize="16sp"
            android:textStyle="italic"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:id="@+id/nav_divider"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#00e8ff"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation" />

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#0c1424"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:id="@+id/nav_home" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/star_big_on" app:tint="#00e8ff" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="#00e8ff" android:textSize="10sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_task" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#ff27b5" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHALLENGE" android:textColor="#ff27b5" android:textSize="10sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_help" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_help" app:tint="#9333EA" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HELP" android:textColor="#9333EA" android:textSize="10sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>